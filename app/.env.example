# Copy to .env in project root or app/ directory
GROQ_API_KEY=your_groq_api_key_here

# Optional overrides — https://console.groq.com/docs/models
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_MAX_TOKENS=768
GROQ_CONTEXT_CHARS=6000
WHISPER_MODEL=tiny
WHISPER_CACHE_DIR=.cache/whisper
EMBEDDING_BACKEND=hash
